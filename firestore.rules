rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to check if user is an Admin
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN']
      );
    }

    // Default deny for all collections
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Users can read/write their own profile OR Admins can do anything
      // Added public read for 'IMPORTED' status to allow account activation flow
      allow read: if isAdmin() || 
                   (isAuthenticated() && request.auth.uid == userId) || 
                   (resource.data.status == 'IMPORTED');
      
      // Allow write if Admin, if ID matches, OR if the authenticated user's email matches the document email
      // (Essential for migrating imported users who don't yet have their UID as document ID)
      allow write: if isAdmin() || 
                    (isAuthenticated() && request.auth.uid == userId) ||
                    (isAuthenticated() && request.auth.token.email == resource.data.email);
    }

    match /interpreters/{interpreterId} {
      // Admins read/write anything. Interpreters only read/write their own profile
      // Added read access for IMPORTED/ONBOARDING status to allow activation profile lookups
      allow read: if isAdmin() || 
                   (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileId == interpreterId) ||
                   (resource.data.status in ['IMPORTED', 'ONBOARDING']);
      allow write: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileId == interpreterId);
    }

    match /bookings/{bookingId} {
      // Admins full access. 
      // Interpreters can read if they are assigned to it or if it's OPENED.
      allow read, write: if isAdmin() || isAuthenticated();
    }

    match /assignments/{assignmentId} {
      allow read, write: if isAdmin() || isAuthenticated();
    }

    match /bookingAssignments/{assignmentId} {
      allow read, write: if isAdmin() || isAuthenticated();
    }

    match /applications/{appId} {
      allow read, write: if isAdmin() || isAuthenticated();
    }

    match /clients/{clientId} {
      allow read, write: if isAdmin() || isAuthenticated();
    }

    match /jobEvents/{eventId} {
      allow read, write: if isAdmin() || isAuthenticated();
    }

    match /clientInvoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    match /interpreterInvoices/{invoiceId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.interpreterId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileId);
      allow write: if isAdmin();
    }

    match /timesheets/{timesheetId} {
      allow read, write: if isAdmin() || isAuthenticated();
    }

    match /systemSettings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /emailTemplates/{templateId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /mail/{mailId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // Generally triggered via cloud functions anyway
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
    }

    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /chatThreads/{threadId} {
      allow read, write: if isAuthenticated();
    }

    match /app_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    match /staff_profiles/{profileId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /jobTitles/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /level_permissions/{permId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
